{
  "name": "god-clause",
  "version": "1.0.0",
  "description": "Embeddable AI governance framework — human-readable trust contracts, runtime policy enforcement, and auditability SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "god-clause": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai-governance",
    "trust-contracts",
    "policy-enforcement",
    "policy-engine",
    "audit",
    "responsible-ai",
    "guardrails",
    "ai-safety",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "mcp",
    "model-context-protocol",
    "pii-redaction",
    "compliance",
    "eu-ai-act",
    "zero-trust",
    "yaml"
  ],
  "author": "George Geronik <george@geronik.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGeronik/God_Clause.git"
  },
  "homepage": "https://github.com/GGeronik/God_Clause#readme",
  "bugs": {
    "url": "https://github.com/GGeronik/God_Clause/issues"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "commander": "^13.1.0",
    "uuid": "^11.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "schemas/",
    "examples/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ]
}
